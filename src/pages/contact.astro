---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />

  <main class="min-h-screen py-8 md:pt-stack-lg md:pb-stack-lg px-4 md:px-grid-margin">
    
    <section class="mb-8 md:mb-stack-lg max-w-4xl">
      <h1 class="font-display text-5xl md:text-[64px] lg:text-[84px] uppercase leading-[0.85] border-l-8 border-primary pl-4 md:pl-6">
        ДАВАЙТЕ<br/><span class="text-secondary italic">ОБСУДИМ</span>
      </h1>
      <p class="font-body-md text-base md:text-xl mt-4 md:mt-6 text-on-surface-variant">
        Открыт для обсуждения сложных проектов по веб-архитектуре, ИИ-интеграциям и автоматизации бизнеса. Выберите удобный способ связи или протестируйте моего ИИ-ассистента в правом нижнем углу экрана.
      </p>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-12 border-y-4 border-on-surface bg-white">
      
      <div class="p-6 md:p-8 lg:p-12 flex flex-col justify-between border-b-4 lg:border-b-0 lg:border-r-4 border-on-surface">
        <div class="space-y-8 md:space-y-12">
          
          <div>
            <p class="font-code text-xs md:text-sm text-secondary uppercase font-bold mb-2">[ ПРЯМОЙ EMAIL ]</p>
            <a href="mailto:a.verzhins@gmail.com" class="group block">
              <h2 class="font-display text-3xl sm:text-4xl md:text-5xl uppercase leading-none hover:italic transition-all break-all">
                a.verzhins@gmail.com
              </h2>
              <div class="w-0 group-hover:w-full h-1 md:h-2 bg-primary-fixed mt-2 transition-all duration-300"></div>
            </a>
          </div>

          <div>
            <p class="font-code text-xs md:text-sm text-secondary uppercase font-bold mb-2">[ БЫСТРАЯ СВЯЗЬ ]</p>
            <a href="https://t.me/averzhry" target="_blank" class="group inline-flex items-center gap-3 md:gap-4 bg-primary-container border-4 border-on-surface px-4 py-3 md:px-6 md:py-4 hard-shadow hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none active:translate-x-[4px] active:translate-y-[4px] active:shadow-none transition-all">
              <span class="material-symbols-outlined !text-2xl md:!text-3xl text-on-surface">send</span>
              <span class="font-label-bold text-lg md:text-xl uppercase text-on-surface">@averzhry</span>
            </a>
          </div>

          <div>
             <p class="font-code text-xs md:text-sm text-on-surface-variant uppercase font-bold mb-2">[ ТЕХНИЧЕСКОЕ РЕЗЮМЕ ]</p>
             <a href="https://alekseyvr.github.io/aleksey.verzhinskiy.ryng.cv/" target="_blank" class="font-label-bold text-base md:text-lg uppercase underline decoration-2 underline-offset-4 hover:text-secondary active:text-secondary transition-colors">
               Смотреть CV на GitHub Pages
             </a>
          </div>
          
        </div>
      </div>

      </div>
  </main>

  <Footer />
</Layout>