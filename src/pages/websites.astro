---
// src/pages/websites.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />

  <main class="min-h-screen py-8 md:py-stack-lg">
    <!-- ЗАГОЛОВОК СТРАНИЦЫ -->
    <section class="px-4 md:px-grid-margin mb-8 md:mb-stack-lg">
      <h1 class="font-display text-4xl md:text-[64px] lg:text-display uppercase leading-[0.85] border-l-8 border-secondary pl-4 md:pl-6">
        ОПУБЛИКОВАННЫЕ<br/><span class="text-on-surface italic">ВЕБ-САЙТЫ</span>
      </h1>
      <p class="font-code text-sm md:text-lg uppercase mt-4 md:mt-6 text-on-surface-variant max-w-2xl">
        [ ПОРТФОЛИО: ВЕБ-САЙТЫ, ОНЛАЙН-КАТАЛОГИ, НАДСТРОЙКИ НАД ПОПУЛЯРНЫМИ CMS ]
      </p>
    </section>

    <!-- СПИСОК ПРОЕКТОВ -->
    <section class="px-4 md:px-grid-margin space-y-8 md:space-y-16">
      
      <!-- Проект 1: Fox Trail -->
      <div class="bg-white border-4 border-on-surface hard-shadow group flex flex-col lg:flex-row overflow-hidden">
        <div class="lg:w-1/2 border-b-4 lg:border-b-0 lg:border-r-4 border-on-surface bg-secondary-container p-6 md:p-12 flex flex-col justify-center relative">
          <div class="absolute inset-0 custom-grid-bg opacity-20"></div>
          <div class="bg-white border-4 border-on-surface p-3 md:p-4 hard-shadow rotate-1 group-hover:rotate-0 transition-transform z-10">
            <div class="w-full h-32 md:h-48 border-2 border-on-surface overflow-hidden relative">
              <img 
                src="/images/foxtrailby.jpg" 
                alt="Fox Trail" 
                class="w-full h-full object-cover object-top grayscale group-hover:grayscale-0 transition-all duration-500 scale-105 group-hover:scale-100 group-active:grayscale-0 group-active:scale-100"
                />
            </div>
            <div class="flex justify-between items-center mt-3 md:mt-4 text-on-surface">
              <span class="font-label-bold text-xs md:text-sm truncate mr-2">🔥 Экстрим / Обучение</span>
              <span class="w-3 h-3 md:w-4 md:h-4 bg-primary-container rounded-full shrink-0"></span>
            </div>
          </div>
        </div>
        
        <div class="lg:w-1/2 p-6 md:p-8 lg:p-12 flex flex-col justify-between gap-6">
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              <span class="bg-primary-container px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">Квиз формы</span>
              <span class="bg-white px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">Календарь событий</span>
              <span class="bg-white px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">Каталог услуг</span>
            </div>
            <h2 class="font-headline-lg text-2xl md:text-3xl lg:text-4xl uppercase">Школа турэндуро и экспедиций Fox Trail</h2>
            <p class="font-body-md text-sm md:text-base lg:text-lg text-on-surface-variant">
              Динамичный посадочный сайт для школы мото-экстрима. Внедрены сложные интерактивные формы захвата (квизы для оценки уровня райдера). Дизайн передает драйв и эмоции от бездорожья, а грамотно выстроенная воронка на сайте конвертирует посетителей в участников экспедиций.
            </p>
          </div>
          <div class="border-t-2 border-on-surface pt-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
              <p class="font-code text-[10px] md:text-xs text-on-surface-variant uppercase">Ниша</p>
              <p class="font-label-bold text-base md:text-lg text-secondary">Экстрим / Обучение</p>
            </div>
            <a href="https://www.foxtrail.by/" target="_blank" class="w-full sm:w-auto justify-center bg-on-surface text-surface px-4 py-3 md:px-6 md:py-3 font-label-bold uppercase text-xs md:text-sm border-2 border-on-surface hover:bg-secondary active:bg-secondary transition-colors inline-flex items-center gap-2">
              Открыть сайт <span class="material-symbols-outlined text-sm">open_in_new</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Проект 2: Plazma -->
      <div class="bg-white border-4 border-on-surface hard-shadow group flex flex-col lg:flex-row-reverse overflow-hidden">
        <div class="lg:w-1/2 border-b-4 lg:border-b-0 lg:border-l-4 border-on-surface bg-primary-fixed p-6 md:p-12 flex flex-col justify-center relative">
          <div class="absolute inset-0 custom-grid-bg opacity-20"></div>
          <div class="bg-white border-4 border-on-surface p-3 md:p-4 hard-shadow -rotate-1 group-hover:rotate-0 transition-transform z-10">
            <div class="w-full h-32 md:h-48 border-2 border-on-surface overflow-hidden relative">
              <img 
                src="/images/plazmamedicalby.png" 
                alt="Plazma Medical" 
                class="w-full h-full object-cover object-top grayscale group-hover:grayscale-0 transition-all duration-500 scale-105 group-hover:scale-100 group-active:grayscale-0 group-active:scale-100"
                />
            </div>
            <div class="flex justify-between items-center mt-3 md:mt-4">
              <span class="font-label-bold text-xs md:text-sm truncate mr-2">🏥 МЕДИЦИНА</span>
              <span class="w-3 h-3 md:w-4 md:h-4 bg-secondary rounded-full shrink-0"></span>
            </div>
          </div>
        </div>
        
        <div class="lg:w-1/2 p-6 md:p-8 lg:p-12 flex flex-col justify-between gap-6">
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              <span class="bg-primary-container px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">Кастомный каталог услуг</span>
              <span class="bg-white px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">CRM</span>
              <span class="bg-white px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">Онлайн запись</span>
            </div>
            <h2 class="font-headline-lg text-2xl md:text-3xl lg:text-4xl uppercase">Медицинский центр Plazma</h2>
            <p class="font-body-md text-sm md:text-base lg:text-lg text-on-surface-variant">
              Многостраничный корпоративный сайт для многопрофильного медицинского центра. Разработана интуитивно понятная навигация по десяткам услуг, структурированные прайс-листы и карточки врачей. Дизайн направлен на формирование доверия у пациентов.
            </p>
          </div>
          <div class="border-t-2 border-on-surface pt-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
              <p class="font-code text-[10px] md:text-xs text-on-surface-variant uppercase">Ниша</p>
              <p class="font-label-bold text-base md:text-lg text-secondary">Медицина / Здоровье</p>
            </div>
            <a href="https://plazma-medical.by/" target="_blank" class="w-full sm:w-auto justify-center bg-on-surface text-surface px-4 py-3 md:px-6 md:py-3 font-label-bold uppercase text-xs md:text-sm border-2 border-on-surface hover:bg-secondary active:bg-secondary transition-colors inline-flex items-center gap-2">
              Открыть сайт <span class="material-symbols-outlined text-sm">open_in_new</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Проект 3: ChemTec -->
      <div class="bg-white border-4 border-on-surface hard-shadow group flex flex-col lg:flex-row overflow-hidden">
        <div class="lg:w-1/2 border-b-4 lg:border-b-0 lg:border-r-4 border-on-surface bg-surface-container-highest p-6 md:p-12 flex flex-col justify-center relative">
          <div class="absolute inset-0 custom-grid-bg opacity-40"></div>
          <div class="bg-white border-4 border-on-surface p-3 md:p-4 hard-shadow rotate-1 group-hover:rotate-0 transition-transform z-10">
            <div class="w-full h-32 md:h-48 border-2 border-on-surface overflow-hidden relative">
              <img 
                src="/images/chemtecgroupru.png" 
                alt="ChemTec Group" 
                class="w-full h-full object-cover object-top grayscale group-hover:grayscale-0 group-active:grayscale-0 transition-all duration-500 scale-105 group-hover:scale-100 group-active:scale-100"
                />
            </div>
            <div class="flex justify-between items-center mt-3 md:mt-4">
              <span class="font-label-bold text-xs md:text-sm truncate mr-2">💼 БИЗНЕС ДЛЯ БИЗНЕСА</span>
              <span class="w-3 h-3 md:w-4 md:h-4 bg-primary-fixed rounded-full shrink-0"></span>
            </div>
          </div>
        </div>
        
        <div class="lg:w-1/2 p-6 md:p-8 lg:p-12 flex flex-col justify-between gap-6">
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              <span class="bg-primary-container px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">ИИ-консультант</span>
              <span class="bg-white px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">Кастомный каталог услуг</span>
              <span class="bg-white px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">B2B</span>
            </div>
            <h2 class="font-headline-lg text-2xl md:text-3xl lg:text-4xl uppercase">ChemTec Group</h2>
            <p class="font-body-md text-sm md:text-base lg:text-lg text-on-surface-variant">
              Строгий корпоративный проект для компании в сфере химических технологий и B2B. Разработан удобный каталог продукции для оптовых клиентов. Особый акцент сделан на четкость подачи технической информации и удобные маршруты для запроса коммерческих предложений.
            </p>
          </div>
          <div class="border-t-2 border-on-surface pt-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
              <p class="font-code text-[10px] md:text-xs text-on-surface-variant uppercase">Ниша</p>
              <p class="font-label-bold text-base md:text-lg text-secondary">Промышленность / B2B</p>
            </div>
            <a href="https://chemtecgroup.ru/" target="_blank" class="w-full sm:w-auto justify-center bg-on-surface text-surface px-4 py-3 md:px-6 md:py-3 font-label-bold uppercase text-xs md:text-sm border-2 border-on-surface hover:bg-secondary active:bg-secondary transition-colors inline-flex items-center gap-2">
              Открыть сайт <span class="material-symbols-outlined text-sm">open_in_new</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Проект 4: Etajerka -->
      <div class="bg-white border-4 border-on-surface hard-shadow group flex flex-col lg:flex-row-reverse overflow-hidden">
        <div class="lg:w-1/2 border-b-4 lg:border-b-0 lg:border-l-4 border-on-surface bg-primary-fixed p-6 md:p-12 flex flex-col justify-center relative">
          <div class="absolute inset-0 custom-grid-bg opacity-20"></div>
          <div class="bg-white border-4 border-on-surface p-3 md:p-4 hard-shadow -rotate-1 group-hover:rotate-0 transition-transform z-10">
            <div class="w-full h-32 md:h-48 border-2 border-on-surface overflow-hidden relative">
              <img 
                src="/images/etajerka.jpg" 
                alt="Etajerka shopping mall" 
                class="w-full h-full object-cover object-top grayscale group-hover:grayscale-0 transition-all duration-500 scale-105 group-hover:scale-100 group-active:grayscale-0 group-active:scale-100"
                />
            </div>
            <div class="flex justify-between items-center mt-3 md:mt-4">
              <span class="font-label-bold text-xs md:text-sm truncate mr-2">🛍️ ТОРГОВЫЙ ЦЕНТР</span>
              <span class="w-3 h-3 md:w-4 md:h-4 bg-secondary rounded-full shrink-0"></span>
            </div>
          </div>
        </div>
        
        <div class="lg:w-1/2 p-6 md:p-8 lg:p-12 flex flex-col justify-between gap-6">
          <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
              <span class="bg-primary-container px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">Интерактивная карта</span>
              <span class="bg-white px-2 py-1 border-2 border-on-surface text-[10px] md:text-xs font-bold font-code">CRM</span>
            </div>
            <h2 class="font-headline-lg text-2xl md:text-3xl lg:text-4xl uppercase">Этажерка Торговый центр</h2>
            <p class="font-body-md text-sm md:text-base lg:text-lg text-on-surface-variant">
              Многостраничный сайт для многопрофильного торгового центра в Бобруйске. Разработана интерактивная карта с навигацией по этажам и магазинам, структурированные разделы с акциями и событиями.
            </p>
          </div>
          <div class="border-t-2 border-on-surface pt-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
              <p class="font-code text-[10px] md:text-xs text-on-surface-variant uppercase">Ниша</p>
              <p class="font-label-bold text-base md:text-lg text-secondary">Торговый центр</p>
            </div>
            <a href="https://etajerka.by/" target="_blank" class="w-full sm:w-auto justify-center bg-on-surface text-surface px-4 py-3 md:px-6 md:py-3 font-label-bold uppercase text-xs md:text-sm border-2 border-on-surface hover:bg-secondary active:bg-secondary transition-colors inline-flex items-center gap-2">
              Ожидает публикации <span class="material-symbols-outlined text-sm">open_in_new</span>
            </a>
          </div>
        </div>
      </div>

    </section>
  </main>

  <Footer />
</Layout>