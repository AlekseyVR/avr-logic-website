---
// src/components/Header.astro
---

<header class="relative flex justify-between items-center px-grid-margin py-stack-sm w-full sticky top-0 z-50 bg-surface border-b-4 border-on-surface shadow-[6px_6px_0px_0px_rgba(26,28,28,1)]">
  
  <!-- <a href="/" class="font-headline-md text-base md:text-xl font-black text-on-surface italic tracking-tighter hover:text-secondary transition-colors max-w-[200px] md:max-w-none leading-tight">
    Automation Velocity Resolution-logic
  </a> -->
  <!-- Логотип AVR Logic -->
  <a href="/" class="flex border-4 border-on-surface w-max hard-shadow hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none active:translate-x-[4px] active:translate-y-[4px] active:shadow-none transition-all">
    <div class="bg-primary-container text-on-surface font-display font-black text-xl md:text-3xl px-2 md:px-4 py-1 border-r-4 border-on-surface">A</div>
    <div class="bg-secondary text-white font-display font-black text-xl md:text-3xl px-2 md:px-4 py-1 border-r-4 border-on-surface">V</div>
    <div class="bg-on-surface text-primary-container font-display font-black text-xl md:text-3xl px-2 md:px-4 py-1 md:border-r-4 border-on-surface">R</div>
    <div class="hidden md:flex bg-white text-on-surface font-code font-bold text-sm px-4 py-1 items-center uppercase">
      Logic
    </div>
  </a>

  <nav class="hidden md:flex gap-gutter items-center">
    <a class="font-label-bold text-label-bold uppercase tracking-tighter text-on-surface-variant hover:text-secondary hover:translate-x-[2px] hover:translate-y-[2px] transition-all" href="/#stack">Услуги</a>
    <a class="font-label-bold text-label-bold uppercase tracking-tighter text-on-surface-variant hover:text-secondary hover:translate-x-[2px] hover:translate-y-[2px] transition-all" href="/websites">Сайты</a>
    <a class="font-label-bold text-label-bold uppercase tracking-tighter text-on-surface-variant hover:text-secondary hover:translate-x-[2px] hover:translate-y-[2px] transition-all" href="/portfolio">ИИ-Портфолио</a>
    <a class="font-label-bold text-label-bold uppercase tracking-tighter text-on-surface-variant hover:text-secondary hover:translate-x-[2px] hover:translate-y-[2px] transition-all" href="/contact">Контакты</a>
  </nav>

  <a class="hidden md:block font-label-bold text-label-bold uppercase bg-primary-container text-on-primary-container px-6 py-3 border-4 border-on-surface shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all active:translate-x-[6px] active:translate-y-[6px]" href="/contact">
    ОБСУДИТЬ ПРОЕКТ
  </a>

  <button class="md:hidden p-2 border-4 border-on-surface bg-white flex items-center justify-center cursor-pointer active:translate-y-[2px] transition-transform" id="menu-toggle-btn" aria-label="Toggle Menu">
    <span class="material-symbols-outlined" id="menu-icon">menu</span>
  </button>

  <div class="hidden absolute top-full left-0 w-full bg-primary-container border-b-4 border-on-surface flex-col p-6 gap-6 shadow-[0px_6px_0px_0px_rgba(26,28,28,1)]" id="mobile-nav">
    <a class="font-display text-2xl uppercase font-black hover:text-secondary transition-colors border-b-2 border-on-surface/10 pb-2" href="/#stack">Услуги</a>
    <a class="font-display text-2xl uppercase font-black hover:text-secondary transition-colors border-b-2 border-on-surface/10 pb-2" href="/websites">Сайты</a>
    <a class="font-display text-2xl uppercase font-black hover:text-secondary transition-colors border-b-2 border-on-surface/10 pb-2" href="/portfolio">ИИ-Портфолио</a>
    <a class="font-display text-2xl uppercase font-black hover:text-secondary transition-colors border-b-2 border-on-surface/10 pb-2" href="/contact">Контакты</a>
    
    <a class="mt-4 text-center font-label-bold text-lg uppercase bg-white text-on-surface px-6 py-4 border-4 border-on-surface shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] active:translate-x-[4px] active:translate-y-[4px] active:shadow-none transition-all" href="/contact">
      ОБСУДИТЬ ПРОЕКТ
    </a>
  </div>
</header>

<script>
  // Логика работы единой кнопки
  const toggleBtn = document.getElementById('menu-toggle-btn');
  const mobileNav = document.getElementById('mobile-nav');
  const menuIcon = document.getElementById('menu-icon');

  // Функция переключения состояний
  const toggleMenu = () => {
    const isHidden = mobileNav?.classList.contains('hidden');
    
    if (isHidden) {
      // Открываем меню
      mobileNav?.classList.remove('hidden');
      mobileNav?.classList.add('flex');
      if (menuIcon) menuIcon.textContent = 'close';
    } else {
      // Закрываем меню
      mobileNav?.classList.add('hidden');
      mobileNav?.classList.remove('flex');
      if (menuIcon) menuIcon.textContent = 'menu';
    }
  };

  // Слушаем клик по бургеру
  toggleBtn?.addEventListener('click', toggleMenu);

  // Закрывать меню при клике на любую ссылку внутри
  const links = mobileNav?.querySelectorAll('a');
  links?.forEach(link => {
    link.addEventListener('click', () => {
      mobileNav?.classList.add('hidden');
      mobileNav?.classList.remove('flex');
      if (menuIcon) menuIcon.textContent = 'menu';
    });
  });
</script>